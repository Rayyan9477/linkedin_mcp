# =============================================================================
# LinkedIn MCP Server Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control — it contains credentials.
# =============================================================================

# --- Required ---

# Your LinkedIn login email
LINKEDIN_USERNAME=your_email@example.com

# Your LinkedIn password
LINKEDIN_PASSWORD=your_password

# --- Optional: AI Features ---

# Anthropic API key — enables AI-powered resume/cover letter generation
# and profile analysis. Get one at: https://console.anthropic.com/
# Without this, core LinkedIn features still work (search, profiles, tracking).
ANTHROPIC_API_KEY=

# Claude model to use for AI generation (default: claude-sonnet-4-20250514)
# AI_MODEL=claude-sonnet-4-20250514

# --- Optional: Server Settings ---

# Directory for cache, application tracking, and generated files
# DATA_DIR=~/.linkedin_mcp/data

# How long to cache LinkedIn API responses in hours (default: 24)
# CACHE_TTL_HOURS=24

# Logging level: DEBUG, INFO, WARNING, ERROR (default: INFO)
# LOG_LEVEL=INFO
